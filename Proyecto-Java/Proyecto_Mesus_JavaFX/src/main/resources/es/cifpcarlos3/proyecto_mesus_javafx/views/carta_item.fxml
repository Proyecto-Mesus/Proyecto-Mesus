<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox styleClass="defaultItem" stylesheets="@../styles/base.css" alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.proyecto_mesus_javafx.controllers.CartaItemController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <ImageView fx:id="img" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
    <VBox alignment="CENTER">
        <Label styleClass="defaultTextTitle" fx:id="textNombre" text="Label" />
        <Label styleClass="defaultText" fx:id="textSet" text="Label" />
        <Label styleClass="defaultText" fx:id="textNumeroSet" text="Label" />
    </VBox>
</HBox>
