<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.web.WebView?>
<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.proyecto_mesus_javafx.controllers.EditarEventoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <TextField fx:id="textFieldNombre" promptText="Nombre" />
    <TextField fx:id="textFieldDescripcion" promptText="Descripción" />

    <WebView fx:id="map" prefHeight="200.0" prefWidth="200.0" />
    <Label fx:id="textUbicacion" text="Selecciona una ubicación" />

    <DatePicker fx:id="datePicker"/>
    <HBox spacing="10">
        <Spinner fx:id="spinnerHora"/>
        <Spinner fx:id="spinnerMinuto"/>
    </HBox>

    <Button fx:id="btnConfirmar" onAction="#editarEvento" mnemonicParsing="false" text="Confirmar" />
    <Button fx:id="btnCancelar" onAction="#salir" mnemonicParsing="false" text="Cancelar" />


</VBox>