<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox styleClass="root" stylesheets="@../styles/base.css" alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.proyecto_mesus_javafx.controllers.MisColeccionesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Button styleClass="defaultButton" fx:id="btnNuevaColeccion" mnemonicParsing="false" onAction="#abrirCrearColeccion" text="Nueva colección" />
    <ListView styleClass="defaultList" fx:id="listViewColecciones"/>
    <Button styleClass="defaultButton" fx:id="btnEditarColeccion" mnemonicParsing="false" onAction="#abrirEditarColeccion" text="Editar" />
    <Button styleClass="defaultButton" fx:id="btnBorrarColeccion" mnemonicParsing="false" onAction="#borrarColeccion" text="Eliminar" />
</VBox>