<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.proyecto_mesus_javafx.controllers.RegisterController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <TextField fx:id="textFieldUser" promptText="Usuario" />
        <TextField fx:id="textFieldEmail" promptText="Correo" />
        <TextField fx:id="textFieldPassword" promptText="Contraseña" />
        <TextField fx:id="textFieldConfirmPassword" promptText="Confirmar contraseña" />
        <Button fx:id="btnRegister" mnemonicParsing="false" onAction="#register" text="Crear cuenta" />

    </children>
</VBox>
