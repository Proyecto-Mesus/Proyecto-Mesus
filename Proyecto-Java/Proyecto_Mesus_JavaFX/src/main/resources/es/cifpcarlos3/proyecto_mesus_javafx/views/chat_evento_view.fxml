<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox styleClass="root" stylesheets="@../styles/base.css" alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="es.cifpcarlos3.proyecto_mesus_javafx.controllers.ChatEventoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Button styleClass="defaultButton" fx:id="btnVolver" mnemonicParsing="false" onAction="#abrirMisEventos" text="Volver" />

    <ListView styleClass="chatList" fx:id="listViewMensajes" />

    <TextField styleClass="defaultTextField" fx:id="textFieldMensaje" onAction="#enviarMensaje" promptText="Enviar mensaje" />
</VBox>
